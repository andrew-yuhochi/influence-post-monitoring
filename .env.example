# Influence Post Monitoring — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# === Required ===

# LLM scoring
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# X / Twitter throwaway account (twikit cookie-based scraping)
TWIKIT_USERNAME=your_twitter_username
TWIKIT_EMAIL=your_twitter_email@example.com
TWIKIT_PASSWORD=your_twitter_password

# WhatsApp — Twilio (primary delivery)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
RECIPIENT_PHONE_E164=+1XXXXXXXXXX

# WhatsApp — CallMeBot (fallback delivery)
CALLMEBOT_PHONE=+1XXXXXXXXXX
CALLMEBOT_API_KEY=your_callmebot_api_key

# Turso cloud database
TURSO_URL=libsql://<your-db>.turso.io
TURSO_TOKEN=your_turso_token

# === Optional (with defaults) ===

# Market data fallback
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Source / delivery selection
SOCIAL_SOURCE=twitter_twikit
DELIVERY_PRIMARY=twilio
DELIVERY_FALLBACK=callmebot

# Paths
DATABASE_PATH=data/signals.db
COOKIES_PATH=data/twitter_cookies.json

# Pipeline tuning
MAX_POSTS_PER_ACCOUNT=10
MIN_ACCOUNTS_THRESHOLD=24
POLL_INTERVAL_HOURS=2
MARKET_HOURS_START_ET=09:00
MARKET_HOURS_END_ET=17:00
MORNING_SEND_ET=09:00
EVENING_SEND_ET=16:45
VIRALITY_VIEWS_THRESHOLD=50000
VIRALITY_REPOSTS_THRESHOLD=500
SCORECARD_MIN_DAYS=20

# Logging
LOG_LEVEL=INFO
TIMEZONE=America/New_York
