# Influence Post Monitoring — Environment Variables
# Copy to .env and fill in real values

# === Required ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email@example.com
TWITTER_PASSWORD=your_twitter_password
RECIPIENT_EMAIL=you@example.com

# === Optional (with defaults) ===
SENDER_EMAIL=Influence Monitor <monitor@yourdomain.com>
TWITTER_SOURCE=twitter_twikit
EMAIL_PROVIDER=resend
DATABASE_PATH=data/signals.db
COOKIES_PATH=data/twitter_cookies.json
MIN_ACCOUNTS_THRESHOLD=13
SIGNAL_MIN_SCORE=2.0
TOP_N_SIGNALS=10
CONVICTION_MIN=2
CORROBORATION_MULTIPLIER=1.5
TRACK_RECORD_MIN_CALLS=5
LOG_LEVEL=INFO
TIMEZONE=America/New_York
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
